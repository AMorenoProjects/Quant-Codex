:1}},"key":"fYB7DSMAbq"}],"key":"mxpe7ZC9D0"},{"type":"text","value":" Escribe una función en Python llamada ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lCXe4CEFLZ"},{"type":"inlineCode","value":"calculate_max_drawdown","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Ow6BFMmhGq"},{"type":"text","value":" que tome una serie temporal de precios y retorne el valor exacto del Maximum Drawdown expresado como un número decimal flotante negativo (por ejemplo, -0.125 para indicar una caída máxima del 12.5%).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gny2u1TTNA"}],"key":"m636IwP8nh"},{"type":"code","lang":"python","value":"\nimport pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\n\ndef calculate_max_drawdown(price_series: pd.Series) -> float:\n\trunning_max = price_series.cummax()\n\t\n\tdrawdown = (price_series - running_max) / running_max\n\t\n\tmax_drawdown = drawdown.min()\n\t\nreturn max_drawdown\n\t\nnp.random.seed(42) daily_returns = np.random.normal(0.001, 0.02, 252) price_index = 100 * (1 + daily_returns).cumprod() \n\nprices = pd.Series(price_index)\n\nmdd = calculate_max_drawdown(prices) \n\nprint(f\"El Maximum Drawdown es: {mdd:.2%}\")\n","position":{"start":{"line":5,"column":1},"end":{"line":28,"column":1}},"key":"iWUqQzkQoz"}],"key":"MEkEpVBPTM"}],"key":"WNhGCeMh3c"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Regresión Lineal y Álgebra Matricial","url":"/content/ml/regresion-lineal-algebra-matricial","group":"Machine Learning"},"next":{"title":"Ejercicio 1: Cálculo de Retornos Simples","url":"/content/exercises/ejercicios-basicos","group":"Ejercicios Prácticos"}}},"domain":"http://localhost:3000"}